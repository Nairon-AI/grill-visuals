    { "id": "remote-render-api", "label": "Send specs to a render API", "description": "Simplifies local setup, but sends project context across a network and creates availability coupling.", "highlights": ["coding-agent", "html-renderer", "local-browser"] },
    { "id": "agent-authored-html", "label": "Let the agent write HTML", "description": "Maximally flexible, but breaks the strict trust boundary and makes quality unpredictable.", "highlights": ["coding-agent", "html-renderer"] }
  ],
