{
  "version": 1,
  "id": "checkout-architecture",
  "family": "architecture",
  "title": "How should checkout cross the new payment boundary?",
  "summary": "The migration keeps order ownership internal while isolating payment authorization and asynchronous receipts.",
  "status": "current",
  "options": [
    { "id": "internal-order-owner", "label": "Keep order ownership internal", "description": "Preserves one internal source of truth while isolating authorization behind a narrow provider boundary.", "recommended": true, "highlights": ["customer", "checkout-api", "order-service", "order-store", "order-events", "receipt-worker"] },
    { "id": "provider-owned-order", "label": "Let the provider own order state", "description": "Reduces internal code but couples product state, recovery, and customer support to an external payment model.", "highlights": ["order-service", "payment-provider"] },
    { "id": "dual-write-migration", "label": "Dual-write during migration", "description": "May smooth cutover, but creates reconciliation and partial-failure risk across two authorities.", "highlights": ["checkout-api", "payment-provider", "order-store"] }
  ],
